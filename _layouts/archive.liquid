---
layout: default
---
<div class="post">
  <header class="post-header">
    {% if page.type == 'categories' %}
      <h1 class="post-title">{{ page.title }}</h1>
    {% elsif page.type == 'year' %}
      <h1 class="post-title">{{ page.date | date: '%Y' }}</h1>
    {% elsif page.type == 'tags' %}
      {% assign clean_title = page.title %}
      {% if clean_title == 'poetry' %}
        {% assign clean_title = 'Poetry' %}
      {% elsif clean_title == 'economics' %}
        {% assign clean_title = 'Econ Essays' %}
      {% elsif clean_title == 'reading' %}
        {% assign clean_title = 'Reading Notes' %}
      {% elsif clean_title == 'fragments' %}
        {% assign clean_title = 'Fragments' %}
      {% endif %}
      <h1 class="post-title">{{ clean_title }}</h1>
    {% endif %}
  </header>

  <article class="archive">
    <div class="archive-list">
      {% for document in page.documents %}
        <div class="archive-item">
          <time class="archive-date" datetime="{{ document.date | date: '%Y-%m-%d' }}">
            {{ document.date | date: '%b %d, %Y' }}
          </time>
          <div class="archive-body">
            {% if document.redirect == blank %}
              <a class="post-link archive-title" href="{{ document.url | relative_url }}">{{ document.title }}</a>
            {% elsif document.redirect contains '://' %}
              <a class="post-link archive-title" href="{{ document.redirect }}" target="_blank">{{ document.title }}</a>
            {% else %}
              <a class="post-link archive-title" href="{{ document.redirect | relative_url }}">{{ document.title }}</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </article>
</div>
